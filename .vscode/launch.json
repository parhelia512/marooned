{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Raylib Game",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/Marooned.exe",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${workspaceFolder}",
      "environment": [
        {
          "name": "PATH",
          "value": "${workspaceFolder}\\dlls\\win64;C:\\msys64\\ucrt64\\bin;${env:PATH}"
        }
      ],
      "externalConsole": true,
      "MIMode": "gdb",
      "miDebuggerPath": "C:/msys64/ucrt64/bin/gdb.exe",
      "preLaunchTask": "Build with Make"
    }
  ]
}



